{
  "name": "@eternalheart/file-preview-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "A modern, feature-rich file preview component library for React and Vue - Monorepo",
  "type": "module",
  "packageManager": "pnpm@10.15.0",
  "scripts": {
    "dev": "pnpm build:lib && (pnpm --filter @eternalheart/react-file-preview dev & pnpm --filter @eternalheart/react-file-preview-example dev)",
    "dev:vue": "pnpm build:lib && (pnpm --filter @eternalheart/vue-file-preview dev & pnpm --filter @eternalheart/vue-file-preview-example dev)",
    "dev:docs": "pnpm --filter @eternalheart/react-file-preview-docs dev",
    "build": "pnpm build:lib && pnpm --filter @eternalheart/react-file-preview-example build && pnpm --filter @eternalheart/vue-file-preview-example build && pnpm --filter @eternalheart/react-file-preview-docs build",
    "build:lib": "pnpm --filter @eternalheart/file-preview-core build && pnpm --filter @eternalheart/react-file-preview build && pnpm --filter @eternalheart/vue-file-preview build",
    "build:lib:react": "pnpm --filter @eternalheart/file-preview-core build && pnpm --filter @eternalheart/react-file-preview build",
    "build:lib:vue": "pnpm --filter @eternalheart/file-preview-core build && pnpm --filter @eternalheart/vue-file-preview build",
    "build:example": "pnpm build:lib:react && pnpm --filter @eternalheart/react-file-preview-example build",
    "build:example:vue": "pnpm build:lib:vue && pnpm --filter @eternalheart/vue-file-preview-example build",
    "build:docs": "pnpm --filter @eternalheart/react-file-preview-docs build",
    "preview:example": "pnpm --filter @eternalheart/react-file-preview-example preview",
    "preview:example:vue": "pnpm --filter @eternalheart/vue-file-preview-example preview",
    "preview:docs": "pnpm --filter @eternalheart/react-file-preview-docs preview",
    "clean": "pnpm -r exec rm -rf dist lib .vitepress/dist node_modules && rm -rf node_modules dist-deploy",
    "lint": "eslint packages --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "gh": "bash scripts/deploy.sh",
    "version:patch:react": "pnpm --filter @eternalheart/react-file-preview version:patch",
    "version:minor:react": "pnpm --filter @eternalheart/react-file-preview version:minor",
    "version:major:react": "pnpm --filter @eternalheart/react-file-preview version:major",
    "pub:react": "pnpm --filter @eternalheart/react-file-preview pub",
    "pub:patch:react": "pnpm version:patch:react && pnpm pub:react",
    "pub:minor:react": "pnpm version:minor:react && pnpm pub:react",
    "pub:major:react": "pnpm version:major:react && pnpm pub:react",
    "version:patch:vue": "pnpm --filter @eternalheart/vue-file-preview version:patch",
    "version:minor:vue": "pnpm --filter @eternalheart/vue-file-preview version:minor",
    "version:major:vue": "pnpm --filter @eternalheart/vue-file-preview version:major",
    "pub:vue": "pnpm --filter @eternalheart/vue-file-preview pub",
    "pub:patch:vue": "pnpm version:patch:vue && pnpm pub:vue",
    "pub:minor:vue": "pnpm version:minor:vue && pnpm pub:vue",
    "pub:major:vue": "pnpm version:major:vue && pnpm pub:vue"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wh131462/file-preview.git"
  },
  "bugs": {
    "url": "https://github.com/wh131462/file-preview/issues"
  },
  "homepage": "https://wh131462.github.io/file-preview",
  "license": "MIT",
  "author": {
    "name": "EternalHeart",
    "email": "hao131462@qq.com",
    "url": "https://github.com/wh131462"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "baseline-browser-mapping": "^2.10.0",
    "eslint": "^9.15.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "less": "^4.5.1",
    "typescript": "^5.6.3"
  }
}