{
  "name": "@eternalheart/react-file-preview",
  "version": "1.5.1",
  "description": "A modern, feature-rich file preview component for React with support for images, videos, audio, PDFs, Office documents (Word, Excel, PowerPoint), Markdown, and code files.",
  "type": "module",
  "main": "./lib/index.cjs",
  "module": "./lib/index.mjs",
  "types": "./lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.mjs",
      "require": "./lib/index.cjs"
    },
    "./style.css": "./lib/index.css"
  },
  "files": [
    "lib",
    "README.md",
    "README.zh-CN.md",
    "PDF_CONFIGURATION.md",
    "LICENSE"
  ],
  "keywords": [
    "react",
    "file-preview",
    "image-viewer",
    "pdf-viewer",
    "video-player",
    "audio-player",
    "document-viewer",
    "office-viewer",
    "ppt-viewer",
    "pptx-viewer",
    "powerpoint-viewer",
    "word-viewer",
    "excel-viewer",
    "markdown-viewer",
    "code-viewer"
  ],
  "homepage": "https://wh131462.github.io/file-preview",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wh131462/file-preview.git",
    "directory": "packages/react-file-preview"
  },
  "bugs": {
    "url": "https://github.com/wh131462/file-preview/issues"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "author": {
    "name": "EternalHeart",
    "email": "hao131462@qq.com",
    "url": "https://github.com/wh131462"
  },
  "scripts": {
    "build:esm": "vite build --mode esm",
    "build:cjs": "vite build --mode cjs",
    "build": "pnpm --filter @eternalheart/file-preview-core build && pnpm build:esm && pnpm build:cjs && tsc --project tsconfig.json",
    "dev": "vite build --mode esm --watch --emptyOutDir false",
    "prepublishOnly": "pnpm build",
    "version:patch": "npm version patch",
    "version:minor": "npm version minor",
    "version:major": "npm version major",
    "pub": "npm publish --registry https://registry.npmjs.com",
    "pub:patch": "pnpm version:patch && pnpm pub",
    "pub:minor": "pnpm version:minor && pnpm pub",
    "pub:major": "pnpm version:major && pnpm pub"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "dependencies": {
    "@cornerstonejs/codec-openjpeg": "^1.3.0",
    "@jsquash/avif": "^2.1.1",
    "@kenjiuno/msgreader": "^1.28.0",
    "@likecoin/epub-ts": "^0.6.0",
    "ag-psd": "^30.1.1",
    "docx-preview": "^0.3.2",
    "exceljs": "^4.4.0",
    "foliate-js": "1.0.1",
    "framer-motion": "^11.11.17",
    "heic2any": "^0.0.4",
    "jpeg2000": "^1.1.1",
    "jsonc-parser": "^3.3.1",
    "jszip": "^3.10.1",
    "katex": "^0.16.45",
    "lucide-react": "^0.460.0",
    "mammoth": "^1.8.0",
    "opentype.js": "^2.0.0",
    "pdfjs-dist": "6.1.200",
    "pptx-preview": "^1.0.7",
    "react-markdown": "^10.1.0",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "shiki": "^1.29.2",
    "utif": "^3.1.0",
    "video.js": "^8.23.4",
    "x-data-spreadsheet": "^1.1.9"
  },
  "devDependencies": {
    "@eternalheart/file-preview-core": "workspace:*",
    "@types/node": "^24.10.1",
    "@types/opentype.js": "1.3.10",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "postcss-prefix-selector": "^2.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.18",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vite-plugin-static-copy": "^3.1.4"
  }
}
