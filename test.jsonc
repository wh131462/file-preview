{
  // 这是单行注释
  "name": "JSONC Test File",
  "version": "1.0.0",
  /*
    这是多行注释
    可以跨越多行
  */
  "features": [
    "支持单行注释 //",
    "支持多行注释 /* */",
    "完全兼容标准 JSON"
  ],
  "config": {
    "enabled": true, // 行尾注释也支持
    "timeout": 3000,
    /* 嵌套对象 */
    "nested": {
      "key": "value"
    }
  }
}
